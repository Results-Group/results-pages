# ── Required ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SESSION_SECRET=random_32_plus_byte_string_here

# ── Optional: Monday.com Client Sync (Results Digital workspace only) ──
# Personal API token from https://monday.com/developers/v2
MONDAY_API_TOKEN=
# Board ID: "Budgets Table" = 2080095574
MONDAY_BOARD_ID=2080095574
# UUID of the "Results Digital" workspace in Supabase (check your workspaces table)
MONDAY_SYNC_WORKSPACE_ID=

# ── Optional: Pizza House Dashboard ──
PIZZAHOUSE_DB_HOST=
PIZZAHOUSE_DB_USER=
PIZZAHOUSE_DB_PASSWORD=
PIZZAHOUSE_DB_NAME=
PIZZAHOUSE_DB_PORT=3306
PIZZAHOUSE_DASHBOARD_PASSWORD=
